# Convex URL used by the published RockHound app.
VITE_CONVEX_URL=https://outstanding-chicken-449.convex.cloud
VITE_CONVEX_SITE_URL=https://outstanding-chicken-449.convex.site
VITE_DEV_AUTH_BYPASS=false

# Authentication
# Convex backend secrets are configured in the Convex dashboard or CLI.
# Required by Convex Auth session/token generation:
# JWT_PRIVATE_KEY=...
# JWKS=...
# AUTH_SECRET=...
# SITE_URL=https://iluvrocks.rocks
# CONVEX_SITE_URL=https://outstanding-chicken-449.convex.site

# Optional: OpenRouter API Key (for AI Identification features)
# OPENROUTER_API_KEY=sk-or-v1-...
