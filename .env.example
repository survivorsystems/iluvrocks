# Convex URL (from your Convex dashboard)
VITE_CONVEX_URL=https://your-instance.convex.cloud
VITE_DEV_AUTH_BYPASS=false

# Authentication
# No secrets needed for development with @convex-dev/auth
# For production, you may need to configure AUTH_SECRET
# AUTH_SECRET=...

# Optional: OpenRouter API Key (for AI Identification features)
# OPENROUTER_API_KEY=sk-or-v1-...
